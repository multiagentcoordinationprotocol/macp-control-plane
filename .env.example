# ── HTTP ──────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# ── Authentication ────────────────────────────────
# Comma-separated list of valid API keys. Empty = auth disabled (dev mode).
# REQUIRED in production — app will fail to start without this.
AUTH_API_KEYS=

# ── Database ─────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/macp_control_plane
DB_POOL_MAX=20                    # Min 2 in production
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000

# ── Runtime (gRPC) ───────────────────────────────
RUNTIME_KIND=rust
RUNTIME_ADDRESS=127.0.0.1:50051
RUNTIME_TLS=false                 # Must be true in production (or set RUNTIME_ALLOW_INSECURE=true)
RUNTIME_ALLOW_INSECURE=true       # Defaults to false in production
RUNTIME_BEARER_TOKEN=             # Required in production when RUNTIME_USE_DEV_HEADER is enabled
RUNTIME_USE_DEV_HEADER=true       # Defaults to false in production
RUNTIME_DEV_AGENT_ID=control-plane
RUNTIME_REQUEST_TIMEOUT_MS=30000  # Warn if < 5000

# ── Circuit Breaker ──────────────────────────────
RUNTIME_CIRCUIT_BREAKER_THRESHOLD=5
RUNTIME_CIRCUIT_BREAKER_RESET_MS=30000

# ── Kickoff Retry ────────────────────────────────
KICKOFF_MAX_RETRIES=3

# ── Stream Consumer ─────────────────────────────
STREAM_IDLE_TIMEOUT_MS=120000
STREAM_MAX_RETRIES=5
STREAM_BACKOFF_BASE_MS=250
STREAM_BACKOFF_MAX_MS=30000
STREAM_SSE_HEARTBEAT_MS=15000

# ── Stream Hub ───────────────────────────────────
# Strategy: memory (default, single-instance) | redis (multi-instance)
# Production warning if memory strategy is used.
STREAM_HUB_STRATEGY=memory
REDIS_URL=                        # Required when STREAM_HUB_STRATEGY=redis

# ── Replay ───────────────────────────────────────
REPLAY_MAX_DELAY_MS=2000
REPLAY_BATCH_SIZE=500

# ── Run Recovery ────────────────────────────────
RUN_RECOVERY_ENABLED=true

# ── Data Retention ───────────────────────────────
# Periodically purges terminal runs, audit logs, and webhook deliveries older than TTL.
# Uses advisory locks for multi-instance safety.
DATA_RETENTION_ENABLED=false
DATA_RETENTION_TTL_DAYS=30        # Min 1 when enabled
DATA_RETENTION_INTERVAL_HOURS=24
DATA_RETENTION_BATCH_SIZE=500

# ── Logging ──────────────────────────────────────
LOG_LEVEL=info

# ── OpenTelemetry ────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=macp-control-plane
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Integration Tests ────────────────────────────
# Runtime mode for integration tests: mock | docker | remote
INTEGRATION_RUNTIME=mock
